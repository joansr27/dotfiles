{
    "name": "pinned",
    "include": ["~/dotfiles/waybar/config_base.jsonc"],

// ====================================

    "layer": "top",
    "position": "top",
    "height": 36,
    //"width": 1100,
    "spacing": 4,
    "margin-left": 12,
    "margin-right": 12,
    "margin-top": 12,
    "margin-bottom": 0,
    

    "modules-left": [
	"group/power-menu",
	"group/workspace-dock"
    ],
    "modules-center": [
	"group/time-date"
    ],


    "modules-right": [
	"group/sound",
	"group/connections",
	"group/batteries",
	"group/pin"
    ],


// ====================================


    "mode": "dock",
    "exclusive": true // Tells Hyprland to reserve space for the bar
}
